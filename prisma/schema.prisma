// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// One record per buy/sell/swap initiated by a user.
/// Amount intentionally NOT stored — privacy is maintained by commitment scheme.
model Transaction {
  id           String   @id @default(uuid())
  wallet       String   // Wallet address (format depends on chain)
  type         String   // buy | sell | swap
  commitment   String   // Commitment hash (can be reused across buy/sell)
  nullifier    String?  @unique // Nullifier prevents double-spending
  token_in     String   // Contract address or symbol
  token_out    String
  status       String   @default("pending") // pending | processing | completed | failed
  tx_hash      String?
  reference_id String?  // Monnify/Flutterwave reference
  currency     String?  // NGN | USD
  bank_account String?
  bank_code    String?
  error        String?
  chain        String   @default("STARKNET") // STARKNET | STACKS
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([wallet])
  @@index([commitment])
  @@index([status])
  @@index([nullifier])
  @@index([chain])
}
