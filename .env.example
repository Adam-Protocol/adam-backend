# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adam_protocol"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Starknet
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_7
STARKNET_CHAIN_ID=SN_SEPOLIA
DEPLOYER_PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...

# Contract addresses (fill after deploy)
ADUSD_ADDRESS=0x...
ADNGN_ADDRESS=0x...
ADAM_SWAP_ADDRESS=0x...
ADAM_POOL_ADDRESS=0x...
USDC_ADDRESS=0x053c91253bc9682c04929ca02ed00b3e423f6710d2ee7e0d5ebb06f3ecf368a8
TREASURY_ADDRESS=0x...

# ExchangeRate-API (free tier)
EXCHANGE_RATE_API_KEY=your_key_here
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# Offramp provider
MONNIFY_API_KEY=your_key_here
MONNIFY_SECRET_KEY=your_secret_here
MONNIFY_BASE_URL=https://api.monnify.com
MONNIFY_CONTRACT_CODE=your_contract_code
