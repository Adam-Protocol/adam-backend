# Server
PORT=4000
NODE_ENV=development
APP_URL=https://your-domain.com

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adam_protocol"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Starknet
STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_10/YOUR_KEY
STARKNET_CHAIN_ID=SN_SEPOLIA
DEPLOYER_PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...

# Contract addresses (fill after deploy)
ADUSD_ADDRESS=0x...
ADNGN_ADDRESS=0x...
ADKES_ADDRESS=0x...
ADGHS_ADDRESS=0x...
ADZAR_ADDRESS=0x...
ADAM_SWAP_ADDRESS=0x...
ADAM_POOL_ADDRESS=0x...
USDC_ADDRESS=0x...
TREASURY_ADDRESS=0x...

# ExchangeRate-API (free tier)
EXCHANGE_RATE_API_KEY=your_key_here
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# Flutterwave (Offramp provider)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_public_key
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_secret_key
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TEST-your_encryption_key
FLUTTERWAVE_WEBHOOK_SECRET_HASH=your_webhook_secret

